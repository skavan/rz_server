# Ubuntu production environment template for rz_server
# Copy to server/.env and fill real values before deploy.
# Use an external shared storage root if multiple servers must share uploads.

# Core runtime
NODE_ENV=production
PORT=5000

# Database
DATABASE_URL=postgresql://app_user:change_me@127.0.0.1:5432/rental_inventory_v2
APP_DB_ROLE=app_role

# Security
JWT_SECRET=change-me-to-a-long-random-secret

# CORS (comma-separated, no trailing slash)
CLIENT_URLS=https://inventory.kavan.us,https://inventory-pdf.kavan.us

# Storage
# Keep these outside the repo checkout in production.
# Shared dataset mounted on this Ubuntu host
UPLOAD_DIR=/srv/rz-data/shared/media
MEDIA_EXPORT_PATH=/srv/rz-data/shared/media-exports

# Logging / diagnostics
FIELD_TRANSFORM_DEBUG=false
LOG_DOUBLE_SLASH_REQUESTS=false
LOG_DOUBLE_SLASH_STACK=false

# API limits
DEFAULT_PAGE_LIMIT=5000
MAX_PAGE_LIMIT=10000
