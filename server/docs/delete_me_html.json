/*
  App utilities: simple tints/shades derived from --secondary via color-mix.
  These have a plain hsl(var(--secondary)) fallback for older browsers.
*/

/* =============================================================================
   PRINT STYLES - Property Damage Report & Declarative Views
   ============================================================================= */
@media print {
	/* Reset body scroll for printing */
	html,
	body {
		overflow: visible !important;
		height: auto !important;
	}

	/* Keep TOC/bookmarks for on-screen navigation, but don't print them */
	.print-bookmarks {
		display: none !important;
	}

	/* Hide non-printable UI elements */
	.print\\:hidden,
	[data-print-hide],
	nav,
	aside,
	header:not([data-print-header]),
	footer:not([data-print-footer]),
	.sidebar,
	.nav-bar,
	.app-shell-sidebar,
	.app-shell-header {
		display: none !important;
	}

	/* Make main content full width */
	main,
	[data-print-container] {
		width: 100% !important;
		max-width: 100% !important;
		margin: 0 !important;
		padding: 0 !important;
	}

	/* Card break behavior - keep borders on nested cards (inventory items) */
	[data-print-card] {
		box-shadow: none !important;
		border: 1px solid #e5e7eb !important;
	}

	/* Location cards (top-level) - remove borders completely */
	[data-print-location-card="true"] {
		border: none !important;
		border-width: 0 !important;
		box-shadow: none !important;
		background: white !important;
	}

	/* Also target by attribute selector for maximum specificity */
	[data-print-card][data-print-location-card="true"] {
		border: none !important;
		border-width: 0 !important;
	}

	/* Avoid breaking inside cards when breakOnCard is set */
	[data-print-break-card="true"] [data-print-card] {
		-moz-column-break-inside: avoid;
		     break-inside: avoid;
		page-break-inside: avoid;
	}

	/* Allow first card to break when allowFirstCardBreak is set (so header + first card can share page) */
	[data-print-allow-first-break="true"] [data-print-grid] > *:first-child [data-print-card] {
		-moz-column-break-inside: auto;
		     break-inside: auto;
		page-break-inside: auto;
	}

	/* Force page break before location cards when breakOnLocation is set */
	[data-print-break-location="true"] [data-print-grid] > * > [data-print-card] {
		-moz-column-break-before: page;
		     break-before: page;
		page-break-before: always;
	}

	/* First location card should not have break before */
	[data-print-break-location="true"] [data-print-grid] > *:first-child > [data-print-card] {
		-moz-column-break-before: auto;
		     break-before: auto;
		page-break-before: auto;
	}

	/* Ensure images print properly - cover mode to fill container */
	img {
		max-width: 100% !important;
		-o-object-fit: cover !important;
		   object-fit: cover !important;
		page-break-inside: avoid;
	}

	/* Force white backgrounds everywhere - remove any grey/muted backgrounds */
	body,
	.print-mode-container,
	[data-print-container],
	[data-print-wrapper],
	[data-print-grid],
	[data-print-card],
	[class*="bg-muted"],
	[class*="bg-gray"],
	[class*="bg-slate"] {
		background: white !important;
		background-color: white !important;
	}

	/* Ensure backgrounds print */
	* {
		-webkit-print-color-adjust: exact !important;
		print-color-adjust: exact !important;
		color-adjust: exact !important;
	}

	/* Adjust spacing for print */
	[data-print-content] {
		padding: 0 !important;
	}

	[data-print-grid] {
		gap: 1rem !important;
	}

	/* Critical: Prevent content clipping in print */
	.print-mode-container,
	[data-print-container],
	[data-print-wrapper],
	[data-print-grid],
	[data-print-card] {
		overflow: visible !important;
		max-height: none !important;
		height: auto !important;
	}

	/* Apply height:auto to nested elements but NOT aspect-ratio containers */
	.print-mode-container > *,
	.print-mode-container > * > *,
	.print-mode-container > * > * > *,
	[data-print-container] > *,
	[data-print-wrapper] > *,
	[data-print-grid] > *,
	[data-print-grid] > * > *,
	[data-print-card] > * {
		overflow: visible !important;
		max-height: none !important;
	}

	/* Force all divs to expand (except aspect containers) */
	.print-mode-container div:not([class*="aspect-"]),
	[data-print-container] div:not([class*="aspect-"]),
	[data-print-wrapper] div:not([class*="aspect-"]),
	[data-print-grid] div:not([class*="aspect-"]) {
		height: auto !important;
		max-height: none !important;
		overflow: visible !important;
	}

	/* Image tiles - preserve aspect ratio and use cover */
	.aspect-square,
	.aspect-video,
	[class*="aspect-"] {
		position: relative !important;
		overflow: hidden !important;
	}

	.aspect-square {
		aspect-ratio: 1 / 1 !important;
	}
	.aspect-video {
		aspect-ratio: 16 / 9 !important;
	}
	.aspect-\[4\/3\] {
		aspect-ratio: 4 / 3 !important;
	}
	.aspect-\[3\/2\] {
		aspect-ratio: 3 / 2 !important;
	}
	.aspect-\[21\/9\] {
		aspect-ratio: 21 / 9 !important;
	}

	/* Images inside aspect containers - fill and cover */
	.aspect-square img,
	.aspect-video img,
	[class*="aspect-"] img {
		position: absolute !important;
		top: 0 !important;
		left: 0 !important;
		width: 100% !important;
		height: 100% !important;
		-o-object-fit: cover !important;
		   object-fit: cover !important;
	}
}

/* =============================================================================
   PRINT FONT SIZES - Applied to .print-mode-container for screen AND print
   ============================================================================= */

/* Property name: 16pt Bold All Caps */
.print-mode-container .print-property-name {
	font-size: 16pt !important;
	font-weight: 700 !important;
	text-transform: uppercase !important;
	letter-spacing: 0.05em !important;
}

/* Report title: 16pt Bold */
.print-mode-container .print-report-title {
	font-size: 16pt !important;
	font-weight: 700 !important;
}

/* Stats row: 12pt */
.print-mode-container .print-stats-row,
.print-mode-container .print-stats-row * {
	font-size: 12pt !important;
}

/* Notes: 12pt */
.print-mode-container .print-notes,
.print-mode-container .print-notes * {
	font-size: 12pt !important;
}

/* Location card headers: 14pt Bold */
.print-mode-container [data-print-location-card="true"] h3,
.print-mode-container [data-print-location-card="true"] .text-lg {
	font-size: 14pt !important;
	font-weight: 700 !important;
}

/* Inventory item titles: 14pt Bold */
.print-mode-container [data-print-card]:not([data-print-location-card="true"]) h3 {
	font-size: 14pt !important;
	font-weight: 700 !important;
}

/* Inventory item subtitles/details: 12pt */
.print-mode-container [data-print-card]:not([data-print-location-card="true"]) .text-sm,
.print-mode-container [data-print-card]:not([data-print-location-card="true"]) .text-xs {
	font-size: 12pt !important;
}

/* Badges: normalize all to same size */
/* Target badges by their stable CVA classes (rounded-full + border) */
.print-mode-container .rounded-full.border {
	font-size: 10pt !important;
	line-height: 1.2 !important;
	padding: 2px 8px !important;
	height: auto !important;
	min-height: unset !important;
	max-height: none !important;
	box-sizing: border-box !important;
}

/* Body text: 12pt */
.print-mode-container [data-print-card] p,
.print-mode-container .text-muted-foreground,
.print-mode-container .whitespace-pre-wrap {
	font-size: 12pt !important;
}

/* Force description text to wrap instead of truncate */
.print-mode-container .truncate,
.print-mode-container .line-clamp-1,
.print-mode-container .line-clamp-2,
.print-mode-container .line-clamp-3,
.print-mode-container [class*="line-clamp"] {
	overflow: visible !important;
	text-overflow: unset !important;
	white-space: normal !important;
	-webkit-line-clamp: unset !important;
	display: block !important;
}

/* General body text in print mode */
.print-mode-container {
	font-size: 12pt !important;
}

/* Page setup - balanced margins */
@page {
	size: letter portrait;
	/* margin: 0.375in; */
	margin-top: 0.4in;
	margin-bottom: 0.25in;
	margin-left: 0.25in;
	margin-right: 0.25in;
	/* @bottom-center {
		content: "My Awesome Document";
	} */
}

/* Print mode container - used when rendering with ?print=1 */
.print-mode-container {
	/* Reset any app-level constraints */
	overflow: visible !important;
	height: auto !important;
	max-height: none !important;
	/* Remove horizontal padding - page margins handle spacing */
	padding-left: 0 !important;
	padding-right: 0 !important;
	margin-left: 0 !important;
	margin-right: 0 !important;
	/* ZOOM: adjust if print appears too small/large */
	zoom: 1.15;
}

/* Critical: Override html/body overflow in print mode */
html:has(.print-mode-container),
html:has(.print-mode-container) body {
	overflow: visible !important;
	height: auto !important;
	max-height: none !important;
}

/* Ensure all containers in print mode can expand fully */
.print-mode-container,
.print-mode-container * {
	max-height: none !important;
}

/* Remove any fixed/absolute positioning that could cause cutoff */
.print-mode-container [data-print-container],
.print-mode-container [data-print-wrapper],
.print-mode-container [data-print-grid] {
	position: static !important;
	overflow: visible !important;
	height: auto !important;
}

.print-mode-container [data-print-container] {
	padding: 0 !important;
}

/* Hide UI controls in print mode */
.print-mode-container .print\\:hidden,
.print-mode-container [data-print-hide],
.print-mode-container button:not([data-print-keep]),
.print-mode-container [role="button"]:not([data-print-keep]) {
	display: none !important;
}

/* But keep badges visible */
.print-mode-container .rounded-full.border {
	display: inline-flex !important;
}

/* Card break behavior in print mode */
.print-mode-container [data-print-card] {
	-moz-column-break-inside: avoid;
	     break-inside: avoid;
	page-break-inside: avoid;
}

/* Remove borders and backgrounds from location cards (top-level cards) in print */
.print-mode-container [data-print-grid] > div > [data-print-card] {
	border: none !important;
	border-left: none !important;
	background: white !important;
	box-shadow: none !important;
}

/* Also remove header backgrounds in print mode */
.print-mode-container [data-print-card] > div:first-child {
	background: transparent !important;
}

/* Remove muted backgrounds that appear as grey boxes */
.print-mode-container .bg-muted\/30,
.print-mode-container .bg-muted\/50,
.print-mode-container .bg-muted {
	background: transparent !important;
}

/* Ensure cards don't have fixed heights that could cause cutoff */
