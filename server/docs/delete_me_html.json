/* === PDF-Specific Overrides === */

        body { 
            font-family: Arial, sans-serif; 
            font-size: 11pt;
            color: #333;
            line-height: 1.4;
            margin: 0;
            padding: 0;
        }
        
        /* Hide interactive elements */
        [data-pdf-hide], .print\:hidden, button, .no-print { 
            display: none !important; 
        }
        
        /* Layout */
        .location-section { margin-bottom: 1.5em; }
        .issue { margin-left: 0.5em; margin-bottom: 0.75em; }
        
        /* Tables */
        table { 
            border-collapse: collapse; 
            width: 100%; 
            margin: 0.5em 0;
        }
        th, td { 
            border: 1px solid #ddd; 
            padding: 6px 8px; 
            text-align: left;
            font-size: 10pt;
        }
        th { background: #f5f5f5; font-weight: 600; }
        
        /* Images */
        img { 
            max-width: 100%; 
            height: auto; 
        }
        .photo-gallery, .grid { 
            display: flex; 
            gap: 8px; 
            flex-wrap: wrap; 
        }
        .photo-gallery img, .grid img { 
            max-width: 180px; 
            max-height: 135px;
            object-fit: cover;
        }
        
        /* Cards */
        [data-super-card] { 
            page-break-inside: avoid;
        }
        
        /* Page breaks */
        [data-pdf-break="before"] { page-break-before: always; }
        [data-pdf-break="after"] { page-break-after: always; }
        [data-pdf-break="avoid"] { page-break-inside: avoid; }
        [data-pdf-flow="keep-with-next"] { page-break-after: avoid; }
        
        /* Print-specific overrides */
        @media print {
            body { margin: 0; }
            [data-pdf-hide] { display: none !important; }
        }
    

/* === Force light mode for PDF === */
:root {
    color-scheme: light;
}
html, body {
    background-color: white !important;
    color: #1a1a1a !important;
}
