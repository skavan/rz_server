# Example env for server_v2 (use .env during development)
# Switch to app_user in prod; commit .env for now while debugging.
DATABASE_URL=postgresql://postgres:password@localhost:5432/rental_inventory_v2
APP_DB_ROLE=app_role
PORT=5000
CLIENT_URLS=http://localhost:3000,http://localhost:3001
JWT_SECRET=replace-me
NODE_ENV=development

# Media Storage
# Use an external path in production (outside repo checkout).
# If multiple servers should share uploads, point each host to the same storage dataset.
# Linux example: /srv/rz-data/shared/media
# Windows example: D:\rz-data\shared\media
# Local dev only: ./uploads
UPLOAD_DIR=./uploads
